---
import { getPost, getPosts } from '../../lib/posts';

export function getStaticPaths() {
	return getPosts().map((post) => ({
		params: { slug: post.slug },
	}));
}

const { slug } = Astro.params;
const post = getPost(slug!);

if (!post) {
	return Astro.redirect('/blog');
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/gl.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{post.title} · georgiy lapin</title>
	</head>
	<body>
		<main class="container">
			<p class="back"><a href="/blog">← back</a></p>
			<article class="post">
				<h1>{post.title}</h1>
				{post.body && <p class="body">{post.body}</p>}
			</article>
		</main>

		<footer class="footer">
			<p>© georgiy lapin 2026</p>
		</footer>

		<style>
            :root {
                --text: #0a0a0a;
                --muted: #6b7280;
                --border: #e5e7eb;
            }

            html, body {
				margin: 0;
				padding: 0;
				min-height: 100vh;
				background: #ddd6d688;
				color: var(--text);
				font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
                line-height: 1.6;
			}

			body {
				display: flex;
				flex-direction: column;
			}

			.container {
				flex: 1;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				max-width: 720px;
				margin: 0 auto;
				padding: 32px 20px;
				text-align: center;
			}

			.back {
				position: absolute;
				top: 32px;
				left: 20px;
				margin: 0;
			}

			.back a {
				color: var(--text);
				text-decoration: none;
				transition: transform .15s ease;
				display: inline-block;
			}

			.back a:hover { transform: scale(1.05); }

			.post {
				max-width: 540px;
			}

			h1 {
				font-size: 30px;
				margin: 0 0 16px;
				font-weight: 600;
			}

			.body {
				margin: 0;
				white-space: pre-wrap;
			}

			.footer {
				border-top: 1px solid var(--border);
				padding: 16px;
				text-align: center;
				color: var(--muted);
			}
		</style>
	</body>
</html>
